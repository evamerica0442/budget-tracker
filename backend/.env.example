# ──────────────────────────────────────────────────────────────────────────────
# Budget Tracker Backend — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── MongoDB (Scheduled Payments & Reconciliation) ───────────────────────────
# For Docker: mongodb://mongo:27017/budget_tracker
# For local:  mongodb://localhost:27017/budget_tracker
MONGODB_URI=mongodb://mongo:27017/budget_tracker

# ── Firebase (Auth, Transactions, Categories, Envelopes) ─────────────────────
# Paste the full JSON service account key as a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Reminder Notifications (Optional — for production) ──────────────────────
# Email (SendGrid)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=noreply@budgettracker.app

# Push (Firebase Cloud Messaging)
# FCM_SERVER_KEY=AAAAxxxxx

# SMS (Twilio)
# TWILIO_ACCOUNT_SID=ACxxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_PHONE=+27820000000